%%{init: {"theme": "base", "themeVariables": {"primaryColor": "#E8F2FF", "primaryBorderColor": "#7AA6D8", "primaryTextColor": "#1D3557", "lineColor": "#6B9DD1", "clusterBkg": "#F8FBFF", "clusterBorder": "#A9C7E8", "fontFamily": "Inter, Arial"}}}%%
flowchart LR
  classDef core fill:#E8F2FF,stroke:#6B9DD1,color:#1D3557,stroke-width:2px;
  classDef storage fill:#DCEEFF,stroke:#8EB4DD,color:#1D3557,stroke-width:1.5px;
  classDef user fill:#CFE7FF,stroke:#6B9DD1,color:#1D3557,stroke-width:2px;
  classDef artifact fill:#F4F8FC,stroke:#A5BDD8,color:#35597F,stroke-width:1.5px;

  user([Usuario]):::user

  subgraph browser["Cliente Web"]
    frontend["Frontend<br/>HTML CSS JavaScript"]:::core
  end

  subgraph backend["Backend FastAPI"]
    api["API REST"]:::core
    jobs["Jobs en </br>memoria"]:::storage
    uploads["jsons/_uploads"]:::storage
  end

  subgraph evmaudit["EVMAudit"]
    runner["Runner"]:::core
    normalizer["Normalizer"]:::core
    correlator["Correlator"]:::core
    adapter["Echidna Adapter"]:::core
    reporter["Reporter"]:::core
  end

  contract["Contrato Solidity"]:::artifact
  report["Informe JSON"]:::artifact

  user --> frontend
  frontend --> api
  api -->|POST /analyze| uploads
  api -->|POST /analyze-code| uploads
  uploads --> contract
  api --> jobs
  api --> runner
  runner --> normalizer
  normalizer --> correlator
  correlator --> adapter
  adapter --> runner
  correlator --> reporter
  runner --> reporter
  reporter --> report
  api --> jobs
  frontend -->|GET /status/job_id| api
  frontend -->|GET /result/job_id| api
  api --> frontend
  frontend --> user