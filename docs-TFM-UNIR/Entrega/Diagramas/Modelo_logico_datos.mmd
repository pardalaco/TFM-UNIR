%%{init: {"theme": "base", "themeVariables": {"primaryColor": "#E8F2FF", "primaryBorderColor": "#7AA6D8", "primaryTextColor": "#1D3557", "lineColor": "#6B9DD1", "fontFamily": "Inter, Arial"}}}%%
classDiagram
  class NormalizedReport {
    +str tool
    +List~NormalizedFinding~ findings
  }

  class NormalizedFinding {
    +str title
    +str description
    +str severity
    +str category
    +str contract
    +str function
    +dict location
    +str swc_id
    +dict raw
  }

  class CorrelatedReport {
    +str contract
    +List~CorrelatedFinding~ findings
  }

  class CorrelatedFinding {
    +str contract
    +str function
    +str swc_id
    +str vuln_type
    +str severity
    +int confidence_score
    +str status
    +List~int~ lines
    +List~str~ confirmed_by
    +dict evidence
  }

  class AdapterMetadata {
    +str wrapper_path
    +str contract_name_echidna
    +List~EchidnaVulnerability~ vulnerabilities
    +int testable_count
    +int non_testable_count
    +int skipped_count
  }

  class EchidnaVulnerability {
    +str swc_id
    +str function
    +List~str~ confirmed_by
    +List~str~ detectors
    +bool echidna_testable
    +str warning
  }

  class FinalReport {
    +dict meta
    +dict summary
    +List~CorrelatedFinding~ findings
    +list echidna_results
  }

  NormalizedReport "1" o-- "*" NormalizedFinding
  CorrelatedReport "1" o-- "*" CorrelatedFinding
  AdapterMetadata "1" o-- "*" EchidnaVulnerability
  FinalReport "1" o-- "*" CorrelatedFinding
  NormalizedFinding --> CorrelatedFinding : correlación
  CorrelatedFinding --> EchidnaVulnerability : propiedades Echidna