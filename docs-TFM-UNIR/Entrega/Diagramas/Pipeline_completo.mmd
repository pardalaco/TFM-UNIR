%%{init: {"theme": "base", "themeVariables": {"primaryColor": "#E8F2FF", "primaryBorderColor": "#7AA6D8", "primaryTextColor": "#1D3557", "lineColor": "#6B9DD1", "clusterBkg": "#F8FBFF", "clusterBorder": "#A9C7E8", "fontFamily": "Inter, Arial"}}}%%
flowchart TD
  classDef process fill:#E8F2FF,stroke:#6B9DD1,color:#1D3557,stroke-width:2px;
  classDef decision fill:#DCEEFF,stroke:#5F91C8,color:#1D3557,stroke-width:2px;
  classDef terminal fill:#CFE7FF,stroke:#6B9DD1,color:#1D3557,stroke-width:2px;
  classDef skip fill:#F4F8FC,stroke:#A5BDD8,color:#35597F,stroke-width:1.5px;

  start([Inicio]):::terminal
  input["Recibir </br> contrato  Solidity"]:::process
  hasName{"¿Se proporciona nombre del contrato?"}:::decision
  useName["Usar nombre proporcionado"]:::process
  detectName["Detectar nombre"]:::process
  pragma["Leer </br> pragma Solidity"]:::process
  solc["Configurar versión de solc"]:::process
  slither["Ejecutar Slither"]:::process
  slitherRaw["Guardar JSON </br> crudo Slither"]:::process
  mythril["Ejecutar Mythril"]:::process
  mythrilRaw["Guardar JSON </br> crudo Mythril"]:::process
  normalizeSlither["Normalizar </br> salida"]:::process
  normalizeMythril["Normalizar </br> salida"]:::process
  group["Agrupar por contrato, función y SWC"]:::process
  severity["Calcular severidad máxima"]:::process
  confidence["Calcular nivel confianza"]:::process
  correlated["Generar findings correlacionados"]:::process
  swc["Consultar catálogo </br> SWC"]:::process
  wrapper["Generar wrapper Solidity"]:::process
  hasWrapper{"¿Wrapper generado?"}:::decision
  echidna["Ejecutar Echidna"]:::process
  fix["Corregir nombres y estados si aplica"]:::process
  fuzzing["Guardar resultados de fuzzing"]:::process
  skip["Omitir ejecución Echidna"]:::skip
  final["Generar informe final"]:::process
  stop([Fin]):::terminal

  start --> input --> hasName
  hasName -- Sí --> useName
  hasName -- No --> detectName
  useName --> pragma
  detectName --> pragma
  pragma --> solc
  solc --> slither --> slitherRaw
  solc --> mythril --> mythrilRaw
  slitherRaw --> normalizeSlither
  mythrilRaw --> normalizeMythril
  normalizeSlither --> group
  normalizeMythril --> group
  group --> severity --> confidence --> correlated
  correlated --> swc --> wrapper --> hasWrapper
  hasWrapper -- Sí --> echidna --> fix --> fuzzing --> final
  hasWrapper -- No --> skip --> final
  final --> stop